# ============================================================
# Environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit real secrets to version control.
# ============================================================

# ── Django ──
SECRET_KEY=<generate-a-secure-key>
DEBUG=0

# Comma-separated list of allowed hosts for production
DJANGO_ALLOWED_HOSTS=bibaj-management.com,www.bibaj-management.com,178.238.225.206

# Comma-separated CSRF trusted origins (must match allowed hosts with scheme)
DJANGO_CSRF_TRUSTED_ORIGINS=https://bibaj-management.com,https://www.bibaj-management.com

# ── Database ──
POSTGRES_DB=bldg_mgm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<set-a-strong-password>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── App settings ──
DJANGO_SETTINGS_MODULE=config.settings.local

# ── KESCO Sync (optional) ──
# Default: 259200 seconds (3 days)
KESCO_SYNC_INTERVAL_SECONDS=259200
